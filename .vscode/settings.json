{
  // GitHub Copilot Configuration
  // For AI assistant instructions, see: copilot-instructions.md
  // For detailed project context, see: AGENTS.md

  "python.testing.pytestArgs": [],
  "python.testing.unittestEnabled": false,
  "python.testing.pytestEnabled": true,
  "python.testing.autoTestDiscoverOnSaveEnabled": true,
  "python.testing.pytestPath": ".venv/bin/pytest",
  "python.testing.cwd": "${workspaceFolder}",
  "python.defaultInterpreterPath": ".venv/bin/python",
  "python.analysis.autoSearchPaths": true,
  "python.analysis.useLibraryCodeForTypes": true,
  "python-envs.pythonProjects": [],

  // Treat Helm templates as templating files instead of plain YAML
  "files.associations": {
    "**/helmchart/**/templates/*.yaml": "jinja-yaml",
    "**/helmchart/**/templates/*.yml": "jinja-yaml",
    "**/helmchart/**/templates/*.tpl": "jinja-yaml",
    "helmchart/**/templates/**/*.yaml": "jinja-yaml",
    "helmchart/**/templates/**/*.yml": "jinja-yaml",
    "helmchart/**/templates/**/*.tpl": "jinja-yaml",
    "helmchart/fairagro-advanced-middleware-api-chart/templates/*.yaml": "jinja-yaml",
    "helmchart/fairagro-advanced-middleware-api-chart/templates/*.yml": "jinja-yaml",
    "helmchart/fairagro-advanced-middleware-api-chart/templates/*.tpl": "jinja-yaml"
  },

  // Code formatting - use ruff for both linting and formatting
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit",
      "source.fixAll.ruff": "explicit"
    }
  },

  "sops-edit.onlyUseButtons": false,
  "sops-edit.tempFilePreExtension": "decrypted",

  "mypy.configFile": "pyproject.toml",

  // Ruff Extension Settings - use same execution mode as pre-commit and CI
  "ruff.path": ["uv", "run", "ruff"],
  "ruff.configuration": "${workspaceFolder}/pyproject.toml",
  "ruff.importStrategy": "fromEnvironment",

  // Pylint Extension Settings
  "pylint.args": [
    "--rcfile=pyproject.toml"
  ],
  "pylint.importStrategy": "fromEnvironment",

  "python-envs.defaultEnvManager": "ms-python.python:venv",

  "remote.autoForwardPortsSource": "process"
}
